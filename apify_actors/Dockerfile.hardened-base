# Base image for MEOK Apify Actors
# Build: docker build -t meok/mcp-base:latest -f Dockerfile.hardened-base .
FROM python:3.11-slim

WORKDIR /app
RUN pip install --no-cache-dir \
    fastmcp==0.4.0 \
    mcp==1.0.0 \
    uvicorn==0.32.0 \
    starlette==0.41.3

# Healthcheck
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fsS http://localhost:8081/healthz || exit 1

EXPOSE 8081
