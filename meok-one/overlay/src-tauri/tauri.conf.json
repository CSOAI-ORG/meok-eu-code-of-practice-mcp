{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MEOK Overlay",
  "version": "0.1.0",
  "identifier": "ai.meok.overlay",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "hud",
        "title": "MEOK",
        "width": 430,
        "height": 660,
        "minWidth": 320,
        "minHeight": 360,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "center": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
