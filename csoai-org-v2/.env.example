# Stripe configuration for csoai-org-v2
# Get keys from https://dashboard.stripe.com/apikeys

# Server-side secret key (sk_live_... or sk_test_...). NEVER prefix with NEXT_PUBLIC_.
STRIPE_SECRET_KEY="REPLACE_WITH_STRIPE_SECRET_KEY"

# Optional: per-product Stripe Price IDs (price_...). If unset, the checkout
# endpoint falls back to inline price_data using the GBP amounts below.
STRIPE_PRICE_PACK_EU_AI_ACT=
STRIPE_PRICE_PACK_GROWTH=
STRIPE_PRICE_PACK_FINANCE=
STRIPE_PRICE_ARTICLE_50_KIT=

# Public key for client-side Stripe Elements (if you add them later).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
