  <text x="120" y="180" text-anchor="middle" fill="#1d4ed8" font-family="Arial, sans-serif" font-size="14" font-weight="bold" dy="5">GOV</text>
  <text x="280" y="180" text-anchor="middle" fill="#1d4ed8" font-family="Arial, sans-serif" font-size="14" font-weight="bold" dy="5">NGO</text>
  <text x="150" y="240" text-anchor="middle" fill="#1d4ed8" font-family="Arial, sans-serif" font-size="12" font-weight="bold" dy="4">ACAD</text>
  <text x="250" y="240" text-anchor="middle" fill="#1d4ed8" font-family="Arial, sans-serif" font-size="12" font-weight="bold" dy="4">TECH</text>
  <line x1="200" y1="170" x2="120" y2="145" stroke="white" stroke-width="2" opacity="0.6"/>
