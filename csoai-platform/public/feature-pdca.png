<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="pdcaGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="300" fill="url(#pdcaGrad)"/>
  <circle cx="200" cy="150" r="90" fill="none" stroke="white" stroke-width="8" stroke-dasharray="100 40" opacity="0.8"/>
  <rect x="150" y="60" width="100" height="40" rx="5" fill="white" opacity="0.9"/>
  <text x="200" y="85" text-anchor="middle" fill="#7c3aed" font-family="Arial, sans-serif" font-size="16" font-weight="bold">PLAN</text>
  <rect x="270" y="130" width="100" height="40" rx="5" fill="white" opacity="0.9"/>
  <text x="320" y="155" text-anchor="middle" fill="#7c3aed" font-family="Arial, sans-serif" font-size="16" font-weight="bold">DO</text>
  <rect x="150" y="200" width="100" height="40" rx="5" fill="white" opacity="0.9"/>
  <text x="200" y="225" text-anchor="middle" fill="#7c3aed" font-family="Arial, sans-serif" font-size="16" font-weight="bold">CHECK</text>
  <rect x="30" y="130" width="100" height="40" rx="5" fill="white" opacity="0.9"/>
  <text x="80" y="155" text-anchor="middle" fill="#7c3aed" font-family="Arial, sans-serif" font-size="16" font-weight="bold">ACT</text>
  <path d="M250 80 L270 130" stroke="white" stroke-width="3" marker-end="url(#arrow)"/>
  <path d="M270 170 L250 200" stroke="white" stroke-width="3"/>
  <path d="M150 220 L130 170" stroke="white" stroke-width="3"/>
  <path d="M130 130 L150 80" stroke="white" stroke-width="3"/>
</svg>