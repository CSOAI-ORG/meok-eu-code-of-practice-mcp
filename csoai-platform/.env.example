# CSOAI Platform - Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=3001

# Database (optional - uses mock data if not set)
DATABASE_URL=mysql://user:password@localhost:3306/csoai

# Stripe (for payment processing)
STRIPE_SECRET_KEY="REPLACE_WITH_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PUBLISHABLE_KEY="REPLACE_WITH_STRIPE_PUBLISHABLE_KEY"

# AI Providers (for 33-agent council voting)
OPENAI_API_KEY="REPLACE_WITH_OPENAI_API_KEY"
ANTHROPIC_API_KEY="REPLACE_WITH_ANTHROPIC_API_KEY"
GOOGLE_AI_API_KEY=xxxxx

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@csoai.org
SMTP_PASS=xxxxx

# Session Secret
SESSION_SECRET=change-this-to-a-random-string

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=https://councilof.ai,https://safetyof.ai,https://csoai.org
