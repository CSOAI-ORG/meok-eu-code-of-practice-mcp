pageType: content
background:
  type: solid
  color: "$primary"
elements:
  - elementId: page-label
    elementType: text
    bounds: [80, 30, 200, 24]
    content:
      style: "$label"
      fontSize: 12
      letterSpacing: 2
      wrap: false
      align: [left, middle]
      text: |
        <p>THE SOLUTION</p>

  - elementId: page-title
    elementType: text
    bounds: [80, 60, 900, 50]
    content:
      style: "$title"
      fontSize: 32
      color: "$textLight"
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>Turn Ecosystem Usage into a Data Moat</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [80, 115, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: left-stat
    elementType: text
    bounds: [80, 160, 400, 100]
    content:
      style: "$bigNumber"
      fontSize: 72
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>255+</strong></p>

  - elementId: left-stat-label
    elementType: text
    bounds: [80, 260, 400, 30]
    content:
      fontSize: 20
      fontFamily: "QuattrocentoSans"
      color: "$muted"
      wrap: false
      align: [left, middle]
      text: |
        <p>MCP Servers generating data</p>

  - elementId: left-desc
    elementType: text
    bounds: [80, 310, 480, 140]
    content:
      style: "$bodyDark"
      fontSize: 18
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p>MEOK DATA transforms MCP servers from <strong style="color:#00bca8;">cost centers into data assets</strong>. Every API call enriches proprietary datasets across 13 governance frameworks.</p>

  - elementId: flywheel-title
    elementType: text
    bounds: [80, 470, 480, 30]
    content:
      fontSize: 16
      fontFamily: "Liter"
      color: "$accent"
      letterSpacing: 2
      wrap: false
      align: [left, middle]
      text: |
        <p>THE FLYWHEEL</p>

  - elementId: flywheel1
    elementType: shape
    bounds: [80, 520, 200, 50]
    shapeName: rect
    fill:
      type: solid
      color: "$darkCardBg"
    border:
      style: solid
      width: 1
      color: "#00788860"

  - elementId: flywheel1-text
    elementType: text
    bounds: [80, 520, 200, 50]
    content:
      fontSize: 14
      fontFamily: "QuattrocentoSans"
      color: "$textLight"
      wrap: false
      align: [center, middle]
      text: |
        <p>More Users</p>

  - elementId: arrow1
    elementType: shape
    bounds: [290, 542, 30, 0]
