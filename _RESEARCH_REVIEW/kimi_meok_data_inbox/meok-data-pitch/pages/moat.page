pageType: content
background:
  type: solid
  color: "$primary"
elements:
  - elementId: page-label
    elementType: text
    bounds: [80, 30, 300, 24]
    content:
      style: "$label"
      fontSize: 12
      letterSpacing: 2
      wrap: false
      align: [left, middle]
      text: |
        <p>COMPETITIVE MOAT</p>

  - elementId: page-title
    elementType: text
    bounds: [80, 60, 900, 50]
    content:
      style: "$title"
      fontSize: 32
      color: "$textLight"
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>4 Structural Advantages</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [80, 115, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: col1-bg
    elementType: shape
    bounds: [80, 155, 255, 480]
    shapeName: rect
    fill:
      type: solid
      color: "$darkCardBg"
    border:
      style: solid
      width: 1
      color: "#00788840"

  - elementId: col1-icon
    elementType: icon
    bounds: [110, 185, 44, 44]
    iconName: "fas:lock"
    fill:
      type: solid
      color: "$accent"

  - elementId: col1-title
    elementType: text
    bounds: [100, 250, 215, 60]
    content:
      fontSize: 20
      fontFamily: "Liter"
      color: "$textLight"
      lineHeight: 1.3
      align: [left, top]
      text: |
        <p><strong>Ecosystem Lock-In</strong></p>

  - elementId: col1-body
    elementType: text
    bounds: [100, 320, 215, 140]
    content:
      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "#a0b0c0"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>255 MCP servers across 13 frameworks.</p>
        <p style="margin-top:8px"><strong style="color:#00bca8;">Replication cost: GBP 2.5M+</strong></p>

