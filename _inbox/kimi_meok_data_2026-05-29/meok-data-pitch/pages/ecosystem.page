    content:
      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "$text"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>De-identified clinical data from Epic, Cerner, NHS Spine</p>

  - elementId: card3-bg
