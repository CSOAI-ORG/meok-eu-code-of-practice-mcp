pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: page-label
    elementType: text
    bounds: [80, 30, 200, 24]
    content:
      style: "$label"
      fontSize: 12
      letterSpacing: 2
      wrap: false
      align: [left, middle]
      text: |
        <p>THE ECOSYSTEM</p>

  - elementId: page-title
    elementType: text
    bounds: [80, 60, 900, 50]
    content:
      style: "$title"
      fontSize: 32
      color: "$primary"
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>255+ MCPs Generating Proprietary Data</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [80, 115, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: card1-bg
    elementType: shape
    bounds: [80, 150, 350, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "#e2e8f0"

  - elementId: card1-icon
    elementType: icon
    bounds: [110, 175, 40, 40]
    iconName: "fas:shield-halved"
    fill:
      type: solid
      color: "$accent"

  - elementId: card1-title
    elementType: text
    bounds: [110, 230, 290, 30]
    content:
      fontSize: 20
      fontFamily: "Liter"
      color: "$primary"
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>Governance Engine</strong></p>

  - elementId: card1-body
    elementType: text
    bounds: [110, 270, 290, 100]
    content:
      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "$text"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>62 tools across EU AI Act, GDPR, HIPAA, NIS2, DORA, CRA</p>

  - elementId: card2-bg
    elementType: shape
    bounds: [465, 150, 350, 240]
    shapeName: rect
    fill:
      type: solid
      color: "$cardBg"
    border:
      style: solid
      width: 1
      color: "#e2e8f0"

  - elementId: card2-icon
    elementType: icon
    bounds: [495, 175, 40, 40]
    iconName: "fas:heart-pulse"
    fill:
      type: solid
      color: "$accent"

  - elementId: card2-title
    elementType: text
