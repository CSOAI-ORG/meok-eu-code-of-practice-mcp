        - content:
            text: |
              <p><strong>Pro</strong></p>
        - content:
            text: |
              <p><strong>Enterprise</strong></p>
      - - content:
            text: |
              <p>Price</p>
        - content:
            text: |
              <p><strong>GBP 0/mo</strong></p>
        - content:
            text: |
              <p><span style="color:#00bca8;"><strong>GBP 79/mo</strong></span></p>
        - content:
            text: |
              <p><span style="color:#00bca8;"><strong>GBP 1,499+/mo</strong></span></p>
      - - content:
            text: |
              <p>Daily Requests</p>
        - content:
            text: |
              <p>100</p>
        - content:
            text: |
              <p>10,000</p>
        - content:
            text: |
              <p>Unlimited</p>
      - - content:
            text: |
              <p>Data Freshness</p>
        - content:
            text: |
              <p>Monthly</p>
        - content:
            text: |
              <p>Real-time</p>
        - content:
            text: |
