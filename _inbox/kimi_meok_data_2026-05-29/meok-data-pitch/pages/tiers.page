      - - content:
            text: |
              <p>API Access</p>
        - content:
            text: |
              <p>Basic</p>
        - content:
            text: |
              <p>Full + SDKs</p>
        - content:
            text: |
              <p>Full + Custom Pipelines</p>
      - - content:
            text: |
              <p>Signed Exports</p>
        - content:
            text: |
              <p>—</p>
