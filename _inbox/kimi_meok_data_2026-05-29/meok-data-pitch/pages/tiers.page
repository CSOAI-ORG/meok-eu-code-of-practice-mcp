              <p>Corporations, Institutions</p>

  - elementId: b2b-badge
    elementType: shape
    bounds: [80, 650, 1120, 40]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"

  - elementId: b2b-text
    elementType: text
    bounds: [80, 650, 1120, 40]
    content:
      fontSize: 16
      fontFamily: "QuattrocentoSans"
      color: "$textLight"
      wrap: false
      align: [center, middle]
