pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: page-label
    elementType: text
    bounds: [80, 30, 200, 24]
    content:
      style: "$label"
      fontSize: 12
      letterSpacing: 2
      wrap: false
      align: [left, middle]
      text: |
        <p>PRICING</p>

  - elementId: page-title
    elementType: text
    bounds: [80, 60, 900, 50]
    content:
      style: "$title"
      fontSize: 32
      color: "$primary"
      wrap: false
      align: [left, middle]
      text: |
        <p><strong>Three Tiers. Three Revenue Streams.</strong></p>

  - elementId: title-accent
    elementType: shape
    bounds: [80, 115, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"

  - elementId: tier-table
    elementType: table
    bounds: [80, 150, 1120, 480]
    columnWidths: [0.22, 0.26, 0.26, 0.26]
    rowHeights: [0.12, 0.15, 0.15, 0.15, 0.15, 0.13, 0.15]
    style: "$default"
    rows:
      - - content:
            text: |
              <p><strong>Feature</strong></p>
