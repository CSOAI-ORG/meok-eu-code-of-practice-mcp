#!/bin/bash
# Setup script for OpenClaw Super Power - All LLMs

CLAWD_DIR="/Users/nicholas/clawd"
OPENCLAW_DIR="$HOME/.openclaw"
CONFIG_FILE="$OPENCLAW_DIR/openclaw.json"
PROVIDERS_CONFIG="$CLAWD_DIR/openclaw-providers-config.json"

set -e

echo "🦞 OpenClaw Super Power Setup"
echo "=============================="
echo ""

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Check if running on macOS
if [[ "$OSTYPE" != "darwin"* ]]; then
    echo -e "${RED}Warning: This script is designed for macOS${NC}"
fi

# Function to check command
check_command() {
    if command -v "$1" &> /dev/null; then
        echo -e "${GREEN}✓${NC} $1 found"
        return 0
    else
        echo -e "${RED}✗${NC} $1 not found"
        return 1
    fi
}

# Check prerequisites
echo "Checking prerequisites..."
check_command openclaw
check_command curl
check_command python3

# Check current OpenClaw status
echo ""
echo "Checking OpenClaw status..."
if curl -s http://localhost:18789/ > /dev/null 2>&1; then
    echo -e "${GREEN}✓${NC} OpenClaw gateway running on port 18789"
else
    echo -e "${YELLOW}!${NC} OpenClaw gateway not running (will start later)"
fi

# Show current models
echo ""
echo "Current models in OpenClaw:"
openclaw models list 2>/dev/null | head -20 || echo "  (gateway not running)"

echo ""
echo "=========================================="
echo "Available LLM Providers to Add"
echo "=========================================="
echo ""
echo "1. OpenAI (GPT-4o, o1, o3-mini)"
echo "   URL: platform.openai.com"
echo "   Cost: Pay per use"
echo ""
echo "2. Google Gemini (2.5 Pro, 2.0 Flash)"
echo "   URL: makersuite.google.com"
echo "   Cost: Free tier + pay per use"
echo ""
echo "3. Groq (Llama 3.3 70B, Mixtral)"
echo "   URL: groq.com"
echo "   Cost: Free tier + pay per use"
echo ""
echo "4. Together AI (Open source models)"
echo "   URL: together.xyz"
echo "   Cost: Pay per use"
echo ""
echo "5. Perplexity (Search-augmented)"
echo "   URL: perplexity.ai"
echo "   Cost: $20/mo for Pro API"
echo ""
echo "6. DeepSeek (V3, R1)"
echo "   URL: platform.deepseek.com"
echo "   Cost: Very cheap pay per use"
echo ""
echo "7. Mistral AI (Large, Codestral)"
echo "   URL: console.mistral.ai"
echo "   Cost: Pay per use"
echo ""
echo "8. xAI Grok (Grok 2)"
echo "   URL: x.ai"
echo "   Cost: Pay per use"
echo ""

echo "=========================================="
echo "Setup Options"
echo "=========================================="
echo ""
echo "What would you like to do?"
echo ""
echo "1) Add ALL providers (you'll need API keys)"
echo "2) Add specific providers"
echo "3) Show me what to add to my shell config"
echo "4) Check which API keys I already have"
echo "5) View full configuration template"
echo "q) Quit"
echo ""

read -p "Enter choice [1-5/q]: " choice

case $choice in
    1)
        echo ""
        echo "Adding all providers..."
        echo "Creating backup of current config..."
        cp "$CONFIG_FILE" "$CONFIG_FILE.backup.$(date +%Y%m%d%H%M%S)"
        
        echo ""
        echo "Please enter your API keys (press Enter to skip):"
        echo ""
        
        read -p "OpenAI API Key (sk-...): " openai_key
        read -p "Google AI API Key (AIza...): " google_key
        read -p "Groq API Key (gsk_...): " groq_key
        read -p "Together AI API Key: " together_key
        read -p "Perplexity API Key (pplx-...): " perplexity_key
        read -p "DeepSeek API Key (sk-...): " deepseek_key
        read -p "Mistral API Key: " mistral_key
        read -p "xAI API Key (xai-...): " xai_key
        
        # Create env file
        ENV_FILE="$OPENCLAW_DIR/.env"
        echo "# OpenClaw API Keys" > "$ENV_FILE"
        echo "# Created: $(date)" >> "$ENV_FILE"
        echo "" >> "$ENV_FILE"
        
        [ -n "$openai_key" ] && echo "OPENAI_API_KEY=$openai_key" >> "$ENV_FILE"
        [ -n "$google_key" ] && echo "GOOGLE_AI_API_KEY=$google_key" >> "$ENV_FILE"
        [ -n "$groq_key" ] && echo "GROQ_API_KEY=$groq_key" >> "$ENV_FILE"
        [ -n "$together_key" ] && echo "TOGETHER_API_KEY=$together_key" >> "$ENV_FILE"
        [ -n "$perplexity_key" ] && echo "PERPLEXITY_API_KEY=$perplexity_key" >> "$ENV_FILE"
        [ -n "$deepseek_key" ] && echo "DEEPSEEK_API_KEY=$deepseek_key" >> "$ENV_FILE"
        [ -n "$mistral_key" ] && echo "MISTRAL_API_KEY=$mistral_key" >> "$ENV_FILE"
        [ -n "$xai_key" ] && echo "XAI_API_KEY=$xai_key" >> "$ENV_FILE"
        
        chmod 600 "$ENV_FILE"
        echo ""
        echo -e "${GREEN}✓${NC} API keys saved to $ENV_FILE"
        echo ""
        echo "Next steps:"
        echo "1. Edit $CONFIG_FILE to add provider configurations"
        echo "2. Add 'source $ENV_FILE' to your ~/.zshrc"
        echo "3. Restart OpenClaw gateway"
        echo ""
        echo "Configuration template available at:"
        echo "  $PROVIDERS_CONFIG"
        ;;
        
    2)
        echo ""
        echo "Which provider would you like to add?"
        echo "1) OpenAI"
        echo "2) Google Gemini"
        echo "3) Groq"
        echo "4) Together AI"
        echo "5) Perplexity"
        echo "6) DeepSeek"
        echo "7) Mistral"
        echo "8) xAI Grok"
        read -p "Enter choice [1-8]: " provider_choice
        
        case $provider_choice in
            1) provider_name="OpenAI"; env_var="OPENAI_API_KEY" ;;
            2) provider_name="Google Gemini"; env_var="GOOGLE_AI_API_KEY" ;;
            3) provider_name="Groq"; env_var="GROQ_API_KEY" ;;
            4) provider_name="Together AI"; env_var="TOGETHER_API_KEY" ;;
            5) provider_name="Perplexity"; env_var="PERPLEXITY_API_KEY" ;;
            6) provider_name="DeepSeek"; env_var="DEEPSEEK_API_KEY" ;;
            7) provider_name="Mistral"; env_var="MISTRAL_API_KEY" ;;
            8) provider_name="xAI Grok"; env_var="XAI_API_KEY" ;;
            *) echo "Invalid choice"; exit 1 ;;
        esac
        
        read -p "Enter $provider_name API Key: " api_key
        
        if [ -n "$api_key" ]; then
            ENV_FILE="$OPENCLAW_DIR/.env"
            echo "export $env_var=$api_key" >> "$ENV_FILE"
            echo -e "${GREEN}✓${NC} Added $provider_name API key"
            echo "Run: source $ENV_FILE"
        fi
        ;;
        
    3)
        echo ""
        echo "Add this to your ~/.zshrc:"
        echo ""
        echo "# OpenClaw Super Power - All LLMs"
        echo "source ~/.openclaw/.env"
        echo ""
        echo "# Optional: Add to PATH"
        echo "export PATH=\"/Users/nicholas/clawd/bin:\$PATH\""
        echo ""
        echo "Then run: source ~/.zshrc"
        ;;
        
    4)
        echo ""
        echo "Checking for existing API keys..."
        echo ""
        
        keys=("OPENAI_API_KEY" "GOOGLE_AI_API_KEY" "GROQ_API_KEY" "TOGETHER_API_KEY" \
              "PERPLEXITY_API_KEY" "DEEPSEEK_API_KEY" "MISTRAL_API_KEY" "XAI_API_KEY" \
              "ANTHROPIC_API_KEY")
        
        for key in "${keys[@]}"; do
            if [ -n "${!key}" ]; then
                echo -e "${GREEN}✓${NC} $key is set"
            else
                echo -e "${RED}✗${NC} $key not set"
            fi
        done
        ;;
        
    5)
        cat "$PROVIDERS_CONFIG"
        ;;
        
    q|Q)
        echo "Goodbye!"
        exit 0
        ;;
        
    *)
        echo "Invalid choice"
        exit 1
        ;;
esac

echo ""
echo "For more info, see: $CLAWD_DIR/OPENCLAW_SUPER_POWER_SETUP.md"
